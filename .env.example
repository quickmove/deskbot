# WiFi Configuration (for ESP32 reference)
WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# LLM Configuration
# LLM Provider: "openai" or "minimax"
LLM_PROVIDER=minimax

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# MiniMax settings (used when LLM_PROVIDER=minimax)
# Get API key from: https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=your_minimax_api_key

# ASR Configuration
ASR_MODEL=base
ASR_LANGUAGE=zh

# TTS Configuration - CosyVoice (本地运行)
# CosyVoice 仓库路径
COSYVOICE_PATH=./CosyVoice
# 模型名称 (可选: CosyVoice-300M, CosyVoice-300M-SFT, CosyVoice-300M-Instruct)
COSYVOICE_MODEL=CosyVoice-300M
# 参考音频（用于音色克隆，可选）
TTS_REF_AUDIO=
TTS_REF_TEXT=
